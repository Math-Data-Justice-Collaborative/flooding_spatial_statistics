# Map 4: GWR residuals
p4 <- ggplot() +
  geom_sf(data = pvd_outline, fill = "grey95", colour = "grey50", linewidth = 0.4) +
  geom_point(data = gwr_df, aes(x = X, y = Y, fill = resid),
